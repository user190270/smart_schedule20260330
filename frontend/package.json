{
  "name": "smart-schedule-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:mobile": "vue-tsc --noEmit && vite build --mode mobile --base ./",
    "preview": "vite preview",
    "cap:copy": "cap copy android",
    "cap:sync": "cap sync android",
    "android:add": "cap add android",
    "android:sync": "npm run build:mobile && cap sync android",
    "android:build": "npm run android:sync && .\\android\\gradlew.bat -p android assembleDebug",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/local-notifications": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "axios": "^1.8.2",
    "pinia": "^2.2.6",
    "vant": "^4.9.17",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.1.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.4"
  }
}
